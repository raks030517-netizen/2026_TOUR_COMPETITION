# Browser origin allowed by CORS
FRONTEND_URL=http://localhost:5173

# data.go.kr tourism, weather and Busan traffic APIs.
# Leave blank to use the built-in Busan tourism demo catalog.
DATA_GO_KR_API_KEY=

# Naver local search API (used by the natural-language travel search endpoint)
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=

# Hosted Gemma endpoint. Gemini 모델은 사용하지 않습니다.
# Leave blank to use ROAMATE's guided demo replies in the chat.
GEMMA_API_KEY=
GEMMA_MODEL=gemma-4-31b-it

# Naver Cloud Directions 15 API.
# Leave blank to use a straight-line estimated route for the demo.
NAVER_DIRECTIONS_BASE_URL=https://maps.apigw.ntruss.com
NAVER_DIRECTIONS_KEY_ID=
NAVER_DIRECTIONS_KEY_SECRET=
